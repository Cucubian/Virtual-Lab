<%- include('../partials/header') %>

<div class="container py-12 px-6">
    <div class="flex items-center gap-4 mb-12">
        <div class="p-4 bg-indigo-600 text-white rounded-2xl shadow-xl shadow-indigo-100 flex items-center justify-center text-3xl">📊</div>
        <div>
            <h1 class="text-4xl font-black text-slate-800 tracking-tight">Admin Dashboard</h1>
            <p class="text-text-muted font-medium">Chào mừng trở lại, giáo viên!</p>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="glass-card p-10 flex items-center gap-8 hover-lift">
            <div class="w-20 h-20 bg-blue-50 text-blue-500 rounded-3xl flex items-center justify-center text-4xl shadow-inner">👨‍🎓</div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Tổng học sinh</p>
                <p class="text-4xl font-black text-slate-800"><%= stats.users %></p>
            </div>
        </div>
        <div class="glass-card p-10 flex items-center gap-8 hover-lift">
            <div class="w-20 h-20 bg-amber-50 text-amber-500 rounded-3xl flex items-center justify-center text-4xl shadow-inner">📝</div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Tổng câu trắc nghiệm</p>
                <p class="text-4xl font-black text-slate-800"><%= stats.quizzes %></p>
            </div>
        </div>
        <div class="glass-card p-10 flex items-center gap-8 hover-lift">
            <div class="w-20 h-20 bg-emerald-50 text-emerald-500 rounded-3xl flex items-center justify-center text-4xl shadow-inner">🔬</div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Thí nghiệm sẵn có</p>
                <p class="text-4xl font-black text-slate-800"><%= stats.experiments %></p>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="glass-card p-12">
        <h2 class="text-2xl font-black text-slate-800 mb-8 pb-4 border-b border-slate-50">Thao tác nhanh</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <a href="/admin/quizzes" class="p-6 rounded-2xl bg-slate-50 hover:bg-indigo-50 border border-slate-100/50 flex items-center gap-4 transition-all group">
                <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-xl group-hover:scale-110 transition-all">📝</div>
                <span class="font-bold text-slate-700">Quản lý trắc nghiệm</span>
            </a>
            <a href="/admin/users" class="p-6 rounded-2xl bg-slate-50 hover:bg-emerald-50 border border-slate-100/50 flex items-center gap-4 transition-all group">
                <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-xl group-hover:scale-110 transition-all">👥</div>
                <span class="font-bold text-slate-700">Quản lý người dùng</span>
            </a>
            <a href="/admin/statistics" class="p-6 rounded-2xl bg-slate-50 hover:bg-amber-50 border border-slate-100/50 flex items-center gap-4 transition-all group">
                <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-xl group-hover:scale-110 transition-all">📈</div>
                <span class="font-bold text-slate-700">Thống kê điểm số</span>
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
