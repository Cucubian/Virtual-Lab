<%- include('../partials/header') %>

<div class="main-container min-h-screen bg-[#f8fafc] py-12">
    <div class="max-w-7xl mx-auto px-6">
        
        <!-- Header Section -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
            <div>
                <nav class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">
                    <a href="/admin/dashboard" class="hover:text-primary transition-colors">Admin</a>
                    <span>/</span>
                    <span class="text-slate-600">Quản lý người dùng</span>
                </nav>
                <h1 class="text-4xl font-black text-slate-900 tracking-tight">Danh sách <span class="text-primary">Người dùng</span></h1>
            </div>
            <a href="/admin/dashboard" class="px-6 py-3 bg-white border border-slate-100 rounded-xl shadow-sm hover:shadow-md transition-all text-sm font-bold text-slate-600 flex items-center gap-2">
                <span>←</span> Quay lại Dashboard
            </a>
        </div>

        <!-- Content Card -->
        <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
            
            <!-- Filter Bar -->
            <div class="p-6 border-b border-slate-50 bg-slate-50/30">
                <form action="/admin/users" method="GET" class="relative max-w-md">
                    <input type="text" name="search" value="<%= locals.search || '' %>" placeholder="Tìm kiếm theo tên hoặc username..." 
                        class="w-full pl-12 pr-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/10 focus:border-primary transition-all text-sm font-medium">
                </form>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full text-left whitespace-nowrap">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-100">
                            <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-wider">Thông tin</th>
                            <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-wider">Tài khoản/Email</th>
                            <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-wider">Trường học</th>
                            <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-wider">Ngày tham gia</th>
                            <th class="px-8 py-4 text-[11px] font-black text-slate-400 uppercase tracking-wider text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(user => { %>
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                    <td class="px-8 py-5">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-lg flex items-center justify-center font-bold">
                                                <%= user.username.charAt(0).toUpperCase() %>
                                            </div>
                                            <div>
                                                <div class="font-bold text-slate-800"><%= user.full_name || user.username %></div>
                                                <div class="text-[10px] font-bold text-slate-400 uppercase">Học sinh</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-5">
                                        <div class="text-sm font-semibold text-slate-600">@<%= user.username %></div>
                                        <div class="text-xs text-slate-400"><%= user.email %></div>
                                    </td>
                                    <td class="px-8 py-5">
                                        <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-md text-xs font-bold border border-slate-200">
                                            <%= user.school_name || 'N/A' %>
                                        </span>
                                    </td>
                                    <td class="px-8 py-5 text-sm text-slate-400 font-medium">
                                        <%= new Date(user.created_at).toLocaleDateString('vi-VN') %>
                                    </td>
                                    <td class="px-8 py-5 text-right">
                                        <a href="/admin/users/delete/<%= user.id %>" 
                                           class="text-xs font-black uppercase tracking-widest text-red-400 hover:text-red-600 transition-colors"
                                           onclick="return confirm('Xóa người dùng này?')">
                                            Xóa hồ sơ
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="px-8 py-20 text-center text-slate-400 font-bold">Danh sách trống.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination Bar -->
            <% if (pagination.totalPages > 1) { %>
                <div class="px-8 py-5 bg-slate-50/50 border-t border-slate-100 flex items-center justify-between">
                    <div class="text-xs font-bold text-slate-400 uppercase tracking-widest">
                        Trang <span class="text-slate-900"><%= pagination.currentPage %></span> / <%= pagination.totalPages %>
                    </div>
                    <div class="flex items-center gap-2">
                        <% if (pagination.hasPrev) { %>
                            <a href="/admin/users?page=<%= pagination.currentPage - 1 %><%= search ? '&search=' + search : '' %>" class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-xs font-bold text-slate-600 hover:bg-slate-50 transition-all">Trước</a>
                        <% } %>
                        
                        <% if (pagination.hasNext) { %>
                            <a href="/admin/users?page=<%= pagination.currentPage + 1 %><%= search ? '&search=' + search : '' %>" class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-xs font-bold text-slate-600 hover:bg-slate-50 transition-all">Sau</a>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
