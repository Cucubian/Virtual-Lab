<%- include('../partials/header') %>

<div class="main-container min-h-screen flex items-center justify-center py-12 px-6 bg-[#f8fafc]">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-[40px] border border-slate-100 shadow-2xl shadow-slate-200/50 p-10 space-y-8 animate-fade-in relative overflow-hidden">
            <!-- Background Decoration -->
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-indigo-50 rounded-full blur-3xl opacity-50"></div>
            
            <div class="relative">
                <div class="flex items-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-indigo-50 text-indigo-600 rounded-full text-[10px] font-black uppercase tracking-widest border border-indigo-100/50 shadow-sm">🔐 Khôi phục</span>
                    <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
                </div>
                <h1 class="text-4xl font-black text-slate-800 tracking-tight leading-none mb-3 italic">Quên <span class="text-indigo-600">Mật khẩu?</span></h1>
                <p class="text-slate-500 font-medium text-sm leading-relaxed">Nhập email của bạn để chúng tôi gửi mã xác thực (OTP) khôi phục tài khoản.</p>
            </div>

            <% if (locals.error) { %>
                <div class="p-4 bg-red-50 text-red-500 rounded-2xl text-xs font-bold border border-red-100 flex items-center gap-3">
                    <span>⚠️</span> <%= error %>
                </div>
            <% } %>

            <form action="/auth/forgot-password" method="POST" class="space-y-6 relative">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Địa chỉ Email</label>
                    <div class="relative group">
                        <input type="email" name="email" required placeholder="example@gmail.com"
                            class="w-full pr-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-500/5 focus:border-indigo-500 outline-none transition-all font-bold text-slate-700 placeholder:text-slate-300">
                    </div>
                </div>

                <button type="submit" class="w-full py-4 bg-indigo-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl shadow-indigo-100 hover:bg-slate-900 transition-all active:scale-95 group">
                    Tiếp tục 
                    <span class="inline-block transition-transform group-hover:translate-x-1 ml-1">→</span>
                </button>
            </form>

            <div class="pt-8 border-t border-slate-50 text-center">
                <a href="/auth/login" class="text-[11px] font-black text-slate-400 uppercase tracking-widest hover:text-indigo-600 transition-colors">Quay lại Đăng nhập</a>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
