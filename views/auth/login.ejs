<%- include('../partials/header') %>

<section class="max-w-md mx-auto my-24 px-6 animate-fade-in">
    <div class="glass-card p-12 shadow-2xl shadow-indigo-100/50">
        <div class="text-center mb-10">
            <div class="w-16 h-16 bg-indigo-50 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-6 shadow-inner">🔑</div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">Đăng nhập</h1>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 border border-red-100 text-red-600 px-6 py-4 rounded-xl text-sm font-bold mb-8 animate-pulse">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <form action="/auth/login" method="POST" class="space-y-6">
            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tên đăng nhập</label>
                <input type="text" name="username" required 
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all font-medium text-slate-700 placeholder:text-slate-300"
                    placeholder="Nhập username của bạn...">
            </div>
            
            <div class="space-y-2 relative">
                <div class="flex justify-between items-center px-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Mật khẩu</label>
                </div>
                <input type="password" name="password" required 
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all font-medium text-slate-700 placeholder:text-slate-300"
                    placeholder="••••••••">
                <div class="flex justify-end pr-2">
                    <a href="/auth/forgot-password" class="text-[10px] font-black text-indigo-500 uppercase tracking-widest hover:underline">Quên mật khẩu?</a>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-full py-4 text-lg mt-4 shadow-xl shadow-indigo-100">
                Vào phòng thí nghiệm
            </button>
        </form>

        <div class="mt-10 pt-8 border-t border-slate-50 text-center space-y-4">
            <p class="text-text-muted text-sm font-medium">Bạn mới đến lần đầu? 
                <a href="/auth/register" class="text-primary font-black hover:underline ml-1">Tạo tài khoản </a>
            </p>
        </div>
    </div>
</section>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('success') === 'password_reset') {
        alert('Chúc mừng! Mật khẩu của bạn đã được thay đổi thành công.');
    }
</script>

<%- include('../partials/footer') %>
