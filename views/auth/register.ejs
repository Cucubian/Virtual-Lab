<%- include('../partials/header') %>

<section class="max-w-md mx-auto my-24 px-6 animate-fade-in">
    <div class="glass-card p-12 shadow-2xl shadow-indigo-100/50">
        <div class="text-center mb-10">
            <div class="w-16 h-16 bg-indigo-50 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-6 shadow-inner">👨‍🎓</div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">Đăng ký mới</h1>
            <p class="text-text-muted mt-2 font-medium italic">Trở thành một nhà khoa học nhí</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 border border-red-100 text-red-600 px-6 py-4 rounded-xl text-sm font-bold mb-8 animate-pulse">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <form action="/auth/register" method="POST" class="space-y-6">
            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Họ và tên</label>
                <input type="text" name="full_name" required 
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all font-medium text-slate-700 placeholder:text-slate-300"
                    placeholder="Nguyễn Văn A">
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tên đăng nhập</label>
                <input type="text" name="username" required 
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all font-medium text-slate-700 placeholder:text-slate-300"
                    placeholder="Ví dụ: hocsinha123">
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Email</label>
                <input type="email" name="email" required 
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all font-medium text-slate-700 placeholder:text-slate-300"
                    placeholder="nguyenvana@gmail.com">
            </div>
            
            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Mật khẩu</label>
                <input type="password" name="password" required 
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all font-medium text-slate-700 placeholder:text-slate-300"
                    placeholder="••••••••">
            </div>

            <button type="submit" class="btn btn-primary w-full py-4 text-lg mt-4 shadow-xl shadow-indigo-100">
            Tạo tài khoản học sinh
            </button>
        </form>

        <div class="mt-10 pt-8 border-t border-slate-50 text-center">
            <p class="text-text-muted text-sm font-medium">Đã có tài khoản? 
                <a href="/auth/login" class="text-primary font-black hover:underline ml-1">Đăng nhập ngay</a>
            </p>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
