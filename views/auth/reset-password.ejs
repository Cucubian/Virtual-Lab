<%- include('../partials/header') %>

<div class="main-container min-h-screen flex items-center justify-center py-12 px-6 bg-[#f8fafc]">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-[40px] border border-slate-100 shadow-2xl shadow-slate-200/50 p-10 space-y-8 animate-fade-in relative overflow-hidden">
            <!-- Background Decoration -->
            <div class="absolute -top-12 -left-12 w-32 h-32 bg-emerald-50 rounded-full blur-2xl opacity-50"></div>
            
            <div class="relative text-center">
                <div class="flex items-center justify-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-emerald-50 text-emerald-600 rounded-full text-[10px] font-black uppercase tracking-widest border border-emerald-100/50 shadow-sm">🔑 Đổi mật khẩu</span>
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                </div>
                <h1 class="text-3xl font-black text-slate-800 tracking-tight leading-none mb-3 italic">Mật khẩu <span class="text-emerald-500">Mới</span></h1>
                <p class="text-slate-500 font-medium text-sm leading-relaxed max-w-xs mx-auto text-center">Cài đặt lại mật khẩu mới cho tài khoản của bạn để hoàn tất quá trình khôi phục.</p>
            </div>

            <% if (locals.error) { %>
                <div class="p-4 bg-red-50 text-red-500 rounded-2xl text-xs font-bold border border-red-100 flex items-center gap-3 text-left">
                    <span>⚠️</span> <%= error %>
                </div>
            <% } %>

            <form action="/auth/reset-password" method="POST" class="space-y-6 relative">
                <input type="hidden" name="email" value="<%= email %>">
                <input type="hidden" name="otp" value="<%= otp %>">
                
                <div class="space-y-4">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Mật khẩu mới</label>
                        <div class="relative group">
        
                            <input type="password" name="newPassword" required placeholder="••••••••"
                                class="w-full pl-16 pr-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-emerald-500/5 focus:border-emerald-500 outline-none transition-all font-bold text-slate-700 placeholder:text-slate-300">
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Nhập lại mật khẩu</label>
                        <div class="relative group">

                            <input type="password" name="confirmPassword" required placeholder="••••••••"
                                class="w-full pl-16 pr-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-emerald-500/5 focus:border-emerald-500 outline-none transition-all font-bold text-slate-700 placeholder:text-slate-300">
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full py-4 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl shadow-emerald-100 hover:bg-slate-900 transition-all active:scale-95 group">
                    Hoàn tất khôi phục
                </button>
            </form>

            <div class="pt-8 border-t border-slate-50 text-center flex flex-col gap-2">
                <a href="/auth/login" class="text-[10px] font-black text-slate-400 hover:text-emerald-500 transition-colors uppercase tracking-widest italic">Hủy bỏ quá trình</a>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
