<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🔬 Phòng Thí Nghiệm Ảo | <%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="bg-background text-text min-h-screen flex flex-col antialiased selection:bg-indigo-100 selection:text-primary">
    <nav class="navbar sticky top-0 z-[100] backdrop-blur-2xl bg-white/75 border-b border-slate-100/50 shadow-sm shadow-indigo-50/50">
        <div class="container px-6 h-20 flex justify-between items-center max-w-7xl mx-auto">
            <a href="/" class="logo text-2xl font-black flex items-center gap-3 group">
                <div class="w-10 h-10 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-xl flex items-center justify-center text-xl shadow-lg shadow-indigo-200 group-hover:scale-110 transition-transform duration-300">
                    <span class="logo-icon text-white drop-shadow-sm">🔬</span> 
                </div>
                <span class="bg-gradient-to-r from-slate-900 to-slate-600 bg-clip-text text-transparent tracking-tight">Virtual Lab</span>
            </a>
            
            <ul class="nav-links hidden lg:flex items-center gap-10 list-none">
                <li><a href="/" class="text-sm font-bold text-slate-500 hover:text-primary transition-all relative group/nav">Trang chủ<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all duration-300 group-hover/nav:w-full"></span></a></li>
                <li><a href="/about" class="text-sm font-bold text-slate-500 hover:text-primary transition-all relative group/nav">Về chúng tôi<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all duration-300 group-hover/nav:w-full"></span></a></li>
                <li class="relative group/parent">
                    <a href="#" class="text-sm font-bold text-slate-500 hover:text-primary transition-all flex items-center gap-1 py-4">Chương trình học<span class="text-[10px] opacity-40">▼</span></a>
                    <div class="absolute top-full left-1/2 -translate-x-1/2 w-64 glass-card p-4 hidden group-hover/parent:flex flex-col gap-2 shadow-2xl shadow-indigo-500/10 border border-slate-50 animate-fade-in z-[110]">
                        <a href="/subject/math" class="p-3 rounded-xl hover:bg-slate-50 flex items-center gap-3 transition-colors text-sm font-bold text-slate-600">📐 Toán học</a>
                        <a href="/subject/physics" class="p-3 rounded-xl hover:bg-slate-50 flex items-center gap-3 transition-colors text-sm font-bold text-slate-600">🍎 Vật lý</a>
                        <a href="/subject/chemistry" class="p-3 rounded-xl hover:bg-slate-50 flex items-center gap-3 transition-colors text-sm font-bold text-slate-600">🧪 Hóa học</a>
                        <a href="/subject/biology" class="p-3 rounded-xl hover:bg-slate-50 flex items-center gap-3 transition-colors text-sm font-bold text-slate-600">🌿 Sinh học</a>
                    </div>
                </li>
                <% if (isLoggedIn) { %>
                    <li class="relative group/user">
                        <a href="#" class="flex items-center gap-3 p-1.5 pr-6 bg-slate-50 rounded-2xl border border-slate-100/50 hover:bg-indigo-50 transition-all font-bold text-slate-700">
                            <div class="w-10 h-10 <%= userRole === 'admin' ? 'bg-amber-500 animate-pulse' : 'bg-indigo-600' %> text-white rounded-xl flex items-center justify-center text-sm shadow-indigo-100 shadow-lg">
                                <%= username.charAt(0).toUpperCase() %>
                            </div>
                            <span class="text-sm truncate max-w-[100px]"><%= username %></span>
                            <span class="text-[10px] opacity-30">▼</span>
                        </a>
                        <!-- Dropdown Menu -->
                        <div class="absolute top-full right-0 w-64 glass-card p-4 hidden group-hover/user:flex flex-col gap-2 shadow-2xl shadow-indigo-500/10 border border-slate-50 animate-fade-in z-[110]">
                            <% if (userRole === 'admin') { %>
                                <a href="/admin/dashboard" class="p-3 rounded-xl hover:bg-slate-50 flex items-center gap-3 transition-colors text-sm font-bold text-primary">📊 Admin Dashboard</a>
                            <% } else { %>
                                <a href="/profile" class="p-3 rounded-xl hover:bg-slate-50 flex items-center gap-3 transition-colors text-sm font-bold text-slate-600">👤 Trang cá nhân</a>
                            <% } %>
                            <div class="h-px bg-slate-50 my-1 mx-2"></div>
                            <a href="/auth/logout" class="p-3 rounded-xl hover:bg-red-50 flex items-center gap-3 transition-colors text-sm font-bold text-red-500">🚪 Đăng xuất</a>
                        </div>
                    </li>
                <% } else { %>
                    <li><a href="/auth/login" class="btn btn-primary px-8 py-3 text-sm shadow-indigo-100">Đăng nhập</a></li>
                <% } %>
            </ul>
            
            <!-- Mobile Menu Toggle (Simplified) -->
            <button class="lg:hidden w-10 h-10 flex flex-col justify-center items-center gap-1.5 opacity-50">
                <div class="w-6 h-0.5 bg-slate-900"></div>
                <div class="w-6 h-0.5 bg-slate-900"></div>
            </button>
        </div>
    </nav>
    <main class="main-content flex-grow relative">
