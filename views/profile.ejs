<%- include('partials/header') %>

<section class="container py-16 px-6 max-w-7xl mx-auto">
    <!-- Header Profile Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
        <div class="md:col-span-1 glass-card p-8 text-center flex flex-col justify-center items-center shadow-xl shadow-indigo-100/50">
            <div class="w-24 h-24 bg-indigo-600 text-white rounded-[32px] flex items-center justify-center text-4xl font-black mb-4 shadow-xl shadow-indigo-200">
                <%= user.username.charAt(0).toUpperCase() %>
            </div>
            <h1 class="text-2xl font-black text-slate-800 tracking-tight"><%= user.full_name || user.username %></h1>
        </div>
        
        <div class="md:col-span-3 grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div class="glass-card p-8 flex flex-col justify-center hover-lift border-none">
                <span class="text-3xl mb-2">🧪</span>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Bài đã làm</p>
                <p class="text-3xl font-black text-slate-800"><%= stats.total %></p>
            </div>
            <div class="glass-card p-8 flex flex-col justify-center hover-lift border-none">
                <span class="text-3xl mb-2">🎯</span>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Điểm trung bình</p>
                <p class="text-3xl font-black text-slate-800"><%= stats.avgScore ? Math.round(stats.avgScore) : 0 %>%</p>
            </div>
            <div class="glass-card p-8 flex flex-col justify-center hover-lift border-none">
                <span class="text-3xl mb-2">💎</span>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Tổng câu đúng</p>
                <p class="text-3xl font-black text-slate-800"><%= stats.totalCorrect || 0 %></p>
            </div>
        </div>
    </div>

    <div class="flex flex-col md:flex-row gap-12">
        <!-- Sidebar Navigation -->
        <aside class="w-full md:w-64 space-y-4">
            <button onclick="switchTab('history')" id="btn-history" class="w-full text-left p-5 rounded-2xl font-bold transition-all flex items-center gap-4 bg-indigo-600 text-white shadow-lg shadow-indigo-100">
                <span>📚</span> Lịch sử bài tập
            </button>
            <button onclick="switchTab('settings')" id="btn-settings" class="w-full text-left p-5 rounded-2xl font-bold transition-all flex items-center gap-4 bg-white text-slate-500 hover:bg-slate-50 border border-slate-100">
                <span>⚙️</span> Cài đặt tài khoản
            </button>
            <div class="h-px bg-slate-100 my-6"></div>

        </aside>

        <!-- Main Content Area -->
        <main class="flex-grow min-h-[500px]">
            <!-- Tab: History -->
            <div id="tab-history" class="animate-fade-in space-y-6">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-3xl font-black text-slate-800">Tiến độ học tập</h2>
                </div>

                <% if (history && history.length > 0) { %>
                    <% history.forEach(item => { 
                        const exp = experiments.find(e => e.id === item.experiment_id);
                    %>
                        <div class="glass-card p-6 flex flex-col sm:flex-row justify-between items-center gap-6 border-none shadow-sm hover:shadow-md transition-shadow">
                            <div class="flex items-center gap-5 flex-grow">
                                <div class="w-14 h-14 bg-slate-50 rounded-xl flex items-center justify-center text-2xl border border-slate-100">🔬</div>
                                <div>
                                    <h3 class="font-bold text-slate-800 text-lg"><%= exp ? exp.title : item.experiment_id %></h3>
                                    <p class="text-xs text-slate-400 font-medium"><%= new Date(item.completed_at).toLocaleDateString('vi-VN') %></p>
                                </div>
                            </div>
                            <div class="flex items-center gap-8">
                                <div class="text-right">
                                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Đúng</p>
                                    <p class="font-black text-slate-700"><%= item.correct_answers %>/<%= item.total_questions %></p>
                                </div>
                                <div class="w-16 h-16 rounded-full border-4 <%= item.score >= 80 ? 'border-emerald-500 text-emerald-600' : 'border-amber-500 text-amber-600' %> flex items-center justify-center font-black text-sm">
                                    <%= item.score %>%
                                </div>
                            </div>
                        </div>
                    <% }); %>

                    <!-- Pagination -->
                    <% if (pagination.totalPages > 1) { %>
                        <div class="flex items-center justify-between pt-8">
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Trang <%= pagination.currentPage %> / <%= pagination.totalPages %></p>
                            <div class="flex gap-2">
                                <% if (pagination.hasPrev) { %>
                                    <a href="/profile?page=<%= pagination.currentPage - 1 %>" class="px-6 py-2 bg-white border border-slate-100 rounded-xl font-bold text-xs text-slate-600 hover:bg-slate-50 transition-all">Trước</a>
                                <% } %>
                                <% if (pagination.hasNext) { %>
                                    <a href="/profile?page=<%= pagination.currentPage + 1 %>" class="px-6 py-2 bg-white border border-slate-100 rounded-xl font-bold text-xs text-slate-600 hover:bg-slate-50 transition-all">Sau</a>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="glass-card p-20 text-center opacity-60">
                        <p class="text-4xl mb-4">📭</p>
                        <p class="font-bold">Bạn chưa có lịch sử bài tập nào.</p>
                        <a href="/quizzes" class="text-primary hover:underline mt-4 inline-block font-bold">Làm ngay thôi!</a>
                    </div>
                <% } %>
            </div>

            <!-- Tab: Settings -->
            <div id="tab-settings" class="hidden animate-fade-in">
                <h2 class="text-3xl font-black text-slate-800 mb-8">Thông tin cá nhân</h2>
                <form action="/profile/update" method="POST" class="glass-card p-10 space-y-8 border-none">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Họ và tên</label>
                            <input type="text" name="full_name" value="<%= user.full_name || '' %>" class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-primary/20 outline-none font-bold text-slate-700">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Email</label>
                            <input type="email" name="email" value="<%= user.email || '' %>" class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-primary/20 outline-none font-bold text-slate-700">
                        </div>
                        <div class="space-y-2 md:col-span-2">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Trường học</label>
                            <input type="text" name="school_name" value="<%= user.school_name || '' %>" placeholder="VD: THCS Chu Văn An" class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-primary/20 outline-none font-bold text-slate-700">
                        </div>
                    </div>
                    
                    <div class="pt-6 border-t border-slate-50 flex justify-end">
                        <button type="submit" class="btn btn-primary px-12 shadow-xl shadow-indigo-100">Lưu thay đổi</button>
                    </div>
                </form>

                <div class="mt-8 p-6 bg-amber-50 rounded-2xl border border-amber-100 flex items-start gap-4">
                    <span class="text-xl">💡</span>
                    <p class="text-sm text-amber-700 font-medium">Bạn có thể cập nhật thông tin này bất cứ lúc nào. Thông tin trường học sẽ giúp giáo viên nhận diện bạn tốt hơn trong bảng điểm tập thể.</p>
                </div>
            </div>
        </main>
    </div>
</section>

<script>
    function switchTab(tab) {
        // Toggle tabs
        document.getElementById('tab-history').classList.toggle('hidden', tab !== 'history');
        document.getElementById('tab-settings').classList.toggle('hidden', tab !== 'settings');
        
        // Update buttons
        const btnHistory = document.getElementById('btn-history');
        const btnSettings = document.getElementById('btn-settings');
        
        if (tab === 'history') {
            btnHistory.className = "w-full text-left p-5 rounded-2xl font-bold transition-all flex items-center gap-4 bg-indigo-600 text-white shadow-lg shadow-indigo-100";
            btnSettings.className = "w-full text-left p-5 rounded-2xl font-bold transition-all flex items-center gap-4 bg-white text-slate-500 hover:bg-slate-50 border border-slate-100";
        } else {
            btnSettings.className = "w-full text-left p-5 rounded-2xl font-bold transition-all flex items-center gap-4 bg-indigo-600 text-white shadow-lg shadow-indigo-100";
            btnHistory.className = "w-full text-left p-5 rounded-2xl font-bold transition-all flex items-center gap-4 bg-white text-slate-500 hover:bg-slate-50 border border-slate-100";
        }
    }
</script>

<%- include('partials/footer') %>
