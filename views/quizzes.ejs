<%- include('partials/header') %>

<!-- Background Decoration -->
<div class="fixed inset-0 -z-10 pointer-events-none opacity-20">
    <div class="absolute top-[30%] left-[-10%] w-[500px] h-[500px] bg-amber-100 blur-[150px] rounded-full"></div>
    <div class="absolute bottom-[20%] right-[-5%] w-[400px] h-[400px] bg-indigo-50 blur-[120px] rounded-full shadow-2xl"></div>
</div>
<section class="page-header w-full max-w-[1700px] mx-auto pt-40 pb-12 text-center animate-fade-in px-6" style="padding-top: 160px;">
    <h1 class="text-6xl md:text-7xl font-black mb-4 tracking-tight text-slate-900 leading-tight">Hệ thống <span class="bg-gradient-to-r from-amber-600 to-amber-400 bg-clip-text text-transparent">Trắc nghiệm Online</span></h1>
</section>

<!-- Filter Section -->
<section class="w-full max-w-[1700px] mx-auto mb-20 px-6">
    <div class="flex flex-wrap justify-center gap-3">
        <button class="filter-btn active px-10 py-3.5 rounded-2xl font-black transition-all duration-300 bg-white shadow-sm border border-slate-100 text-slate-600 hover:border-amber-400 [&.active]:bg-amber-500 [&.active]:text-white [&.active]:border-amber-500 text-sm uppercase tracking-wide" data-subject="all">
            Tất cả bài học
        </button>
        <% subjects.forEach(subject => { %>
            <button class="filter-btn px-10 py-3.5 rounded-2xl font-black transition-all duration-300 bg-white shadow-sm border border-slate-100 text-slate-600 hover:border-amber-400 [&.active]:bg-amber-500 [&.active]:text-white [&.active]:border-amber-500 flex items-center gap-3 text-sm uppercase tracking-wide" data-subject="<%= subject.id %>">
                <span class="text-lg"><%= subject.icon %></span> <%= subject.name %>
            </button>
        <% }); %>
    </div>
</section>

<section class="quizzes-section w-full max-w-[1700px] mx-auto pb-32">
    <div id="quizzes-grid" class="experiment-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 px-6">
        <% quizzes.forEach((exp, index) => { %>
            <div class="quiz-card experiment-card glass-card hover-lift flex flex-col h-full relative overflow-hidden group border-none shadow-2xl" data-subject="<%= exp.subject %>">
                <div class="experiment-badge absolute top-6 right-6 bg-amber-500 text-white px-5 py-2 rounded-full text-[9px] font-black uppercase tracking-widest z-10 shadow-xl shadow-amber-200/50">
                    <%= exp.quizCount %> CÂU HỎI
                </div>

                <div class="subject-tag absolute top-6 left-6 bg-white/95 backdrop-blur-md text-slate-800 px-4 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest border border-slate-100 shadow-sm z-10 flex items-center gap-2">
                    <span class="text-xs"><%= exp.subjectIcon %></span> <%= exp.subjectName %>
                </div>
                
                <div class="experiment-preview h-64 bg-slate-50 flex items-center justify-center relative overflow-hidden group-hover:bg-amber-50/50 transition-colors duration-500 border-b border-slate-50">
                    <span class="text-[120px] font-black opacity-[0.03] group-hover:opacity-[0.01] transition-all duration-700 pointer-events-none absolute select-none">
                        <%= exp.subjectIcon %>
                    </span>
                    <!-- Center Logo/Icon - Freed from box -->
                    <div class="flex items-center justify-center group-hover:rotate-6 group-hover:scale-[1.3] transition-all duration-700 relative z-10">
                        <% if (exp.subjectLogo) { %>
                            <img src="<%= exp.subjectLogo %>" alt="<%= exp.subjectName %>" class="w-40 h-40 object-contain drop-shadow-[0_20px_20px_rgba(0,0,0,0.15)]">
                        <% } else { %>
                            <span class="text-[120px] drop-shadow-[0_20px_20px_rgba(0,0,0,0.15)] select-none pointer-events-none transition-transform"><%= exp.subjectIcon %></span>
                        <% } %>
                    </div>
                    <div class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-transparent via-amber-200 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
                
                <div class="experiment-info p-8 flex flex-col flex-grow bg-white">
                    <div class="space-y-4 mb-10">
                        <h3 class="text-3xl font-black text-slate-800 group-hover:text-amber-600 transition-colors leading-tight line-clamp-2 min-h-[4.5rem]"><%= exp.title %></h3>
                        <p class="text-text-muted leading-relaxed font-medium line-clamp-2 text-sm"><%= exp.description %></p>
                    </div>
                    
                    <a href="/experiment/<%= exp.id %>#quiz" class="btn bg-amber-500 text-white hover:bg-amber-600 py-4.5 text-lg font-black rounded-2xl shadow-xl shadow-amber-100 mt-auto group/btn transition-all active:scale-95 text-center flex items-center justify-center gap-3" onclick="sessionStorage.setItem('activeTab', 'quiz')">
                        LUYỆN TẬP NGAY <span class="text-xl group-hover/btn:translate-x-2 transition-transform duration-300">→</span>
                    </a>
                </div>
            </div>
        <% }); %>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-20 animate-fade-in">
        <div class="text-8xl mb-6">🔍</div>
        <h3 class="text-3xl font-black text-slate-800 mb-4">Không tìm thấy bài trắc nghiệm</h3>
        <p class="text-text-muted text-lg font-medium">Bạn hãy thử chọn môn học khác nhé!</p>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const quizCards = document.querySelectorAll('.quiz-card');
    const emptyState = document.getElementById('empty-state');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const subjectId = btn.dataset.subject;

            // Update UI buttons
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            let visibleCount = 0;
            quizCards.forEach(card => {
                if (subjectId === 'all' || card.dataset.subject === subjectId) {
                    card.style.display = 'flex';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            // Toggle empty state
            if (visibleCount === 0) {
                emptyState.classList.remove('hidden');
            } else {
                emptyState.classList.add('hidden');
            }
        });
    });
});
</script>

<%- include('partials/footer') %>
